        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Register($input: RegisterInput!) {\n  register(input: $input) {\n    accessToken\n    refreshToken\n    user {\n      id\n      email\n      createdAt\n      updatedAt\n    }\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"email\": \"user@example.com\",\n    \"password\": \"password123\"\n  }\n}"
              }
            },
            "url": {
              "raw": "{{auth_url}}",
              "host": ["{{auth_url}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.register) {",
                  "    pm.collectionVariables.set('access_token', jsonData.data.register.accessToken);",
                  "    pm.collectionVariables.set('refresh_token', jsonData.data.register.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
